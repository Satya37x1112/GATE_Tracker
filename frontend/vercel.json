{
    "rewrites": [
        {
            "source": "/((?!sitemap\\.xml|robots\\.txt|google[a-z0-9]+\\.html).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}